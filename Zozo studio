  .section-tag{display:inline-block;color:var(--gold);font-size:0.73rem;letter-spacing:4px;text-transform:uppercase;margin-bottom:14px;padding-right:36px;position:relative;}
  .section-tag::after{content:'';position:absolute;right:0;top:50%;width:24px;height:1px;background:var(--gold);}
  .section-title{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,3.5vw,2.6rem);line-height:1.2;margin-bottom:14px;}
  .section-title em{font-style:italic;color:var(--gold);}

  /* PROBLEM / SOLUTION */
  .prob-sol{background:var(--blue2);}
