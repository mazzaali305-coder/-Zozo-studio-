<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Zozo Studio — لوحة التحكم</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;900&family=Playfair+Display:ital,wght@0,700;1,400&display=swap" rel="stylesheet">
<style>
:root {
  --gold: #C9A84C;
  --gold-light: #E8C96A;
  --gold-dim: rgba(201,168,76,0.12);
  --dark: #080808;
  --dark2: #0F0F0F;
  --dark3: #161616;
  --dark4: #1E1E1E;
  --dark5: #252525;
  --white: #F5F0E8;
  --white-dim: rgba(245,240,232,0.55);
  --white-faint: rgba(245,240,232,0.07);
  --green: #2ECC71;
  --red: #E74C3C;
  --blue: #3498DB;
  --sidebar-w: 260px;
}

* { margin:0; padding:0; box-sizing:border-box; }
body { background:var(--dark); color:var(--white); font-family:'Cairo',sans-serif; display:flex; min-height:100vh; overflow-x:hidden; }

/* ══════════════════════════════
   SIDEBAR
══════════════════════════════ */
.sidebar {
  width: var(--sidebar-w);
  background: var(--dark2);
  border-left: 1px solid rgba(201,168,76,0.1);
  display: flex;
  flex-direction: column;
  position: fixed;
  top:0; right:0; bottom:0;
  z-index: 50;
  transition: transform 0.3s;
}

.sidebar-logo {
  padding: 28px 24px 20px;
  border-bottom: 1px solid rgba(201,168,76,0.08);
}

.logo-mark {
  width: 44px; height: 44px;
  background: var(--gold);
  display: flex; align-items: center; justify-content: center;
  font-family: 'Playfair Display', serif;
  font-size: 1.4rem;
  color: var(--dark);
  font-style: italic;
  margin-bottom: 10px;
}

.sidebar-logo h2 {
  font-family: 'Playfair Display', serif;
  font-size: 1.1rem;
  color: var(--white);
}

.sidebar-logo span {
  font-size: 0.7rem;
  color: var(--gold);
  letter-spacing: 3px;
  text-transform: uppercase;
}

.sidebar-nav {
  flex: 1;
  padding: 20px 0;
  overflow-y: auto;
}

.nav-section-label {
  font-size: 0.65rem;
  letter-spacing: 3px;
  color: rgba(245,240,232,0.25);
  text-transform: uppercase;
  padding: 16px 24px 8px;
}

.nav-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 11px 24px;
  cursor: pointer;
  color: var(--white-dim);
  font-size: 0.88rem;
  transition: all 0.25s;
  border-right: 3px solid transparent;
  position: relative;
}

.nav-item:hover { color: var(--white); background: var(--white-faint); }

.nav-item.active {
  color: var(--gold);
  background: var(--gold-dim);
  border-right-color: var(--gold);
}

.nav-icon { font-size: 1rem; width: 20px; text-align: center; }

.nav-badge {
  margin-right: auto;
  background: var(--gold);
  color: var(--dark);
  font-size: 0.6rem;
  font-weight: 700;
  padding: 2px 7px;
  border-radius: 10px;
}

.sidebar-footer {
  padding: 20px 24px;
  border-top: 1px solid rgba(201,168,76,0.08);
}

.site-status {
  display: flex;
  align-items: center;
  gap: 10px;
  background: var(--dark3);
  padding: 12px 16px;
  border: 1px solid rgba(46,204,113,0.2);
}

.status-dot {
  width: 8px; height: 8px;
  background: var(--green);
  border-radius: 50%;
  animation: blink 2s infinite;
}

@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }

.status-text { font-size: 0.78rem; }
.status-text strong { display:block; color:var(--green); font-size:0.72rem; }

/* ══════════════════════════════
   MAIN CONTENT
══════════════════════════════ */
.main {
  margin-right: var(--sidebar-w);
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

.topbar {
  background: var(--dark2);
  border-bottom: 1px solid rgba(201,168,76,0.08);
  padding: 16px 32px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 40;
}

.page-title { font-size: 1rem; font-weight: 700; }
.page-breadcrumb { font-size: 0.75rem; color: var(--white-dim); margin-top: 2px; }

.topbar-actions { display: flex; gap: 12px; align-items: center; }

.btn {
  padding: 9px 20px;
  font-family: 'Cairo', sans-serif;
  font-size: 0.82rem;
  font-weight: 600;
  cursor: pointer;
  border: none;
  transition: all 0.25s;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  text-decoration: none;
}

.btn-gold { background: var(--gold); color: var(--dark); }
.btn-gold:hover { background: var(--gold-light); transform: translateY(-1px); }
.btn-outline { background: transparent; border: 1px solid rgba(245,240,232,0.15); color: var(--white-dim); }
.btn-outline:hover { border-color: var(--gold); color: var(--gold); }
.btn-danger { background: rgba(231,76,60,0.15); border: 1px solid rgba(231,76,60,0.3); color: var(--red); }
.btn-success { background: rgba(46,204,113,0.15); border: 1px solid rgba(46,204,113,0.3); color: var(--green); }
.btn-sm { padding: 6px 14px; font-size: 0.76rem; }

.content-area {
  padding: 32px;
  flex: 1;
}

/* ══════════════════════════════
   PANELS (Tabs)
══════════════════════════════ */
.panel { display: none; }
.panel.active { display: block; }

/* ══════════════════════════════
   DASHBOARD HOME
══════════════════════════════ */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
  margin-bottom: 32px;
}

.stat-card {
  background: var(--dark3);
  border: 1px solid rgba(245,240,232,0.05);
  padding: 24px;
  position: relative;
  overflow: hidden;
  transition: border-color 0.3s;
}

.stat-card:hover { border-color: rgba(201,168,76,0.2); }

.stat-card::before {
  content: '';
  position: absolute;
  top: 0; right: 0;
  width: 3px; height: 100%;
  background: var(--gold);
  opacity: 0.4;
}

.stat-label { font-size: 0.72rem; color: var(--white-dim); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 10px; }
.stat-value { font-family: 'Playfair Display', serif; font-size: 2rem; color: var(--gold); }
.stat-change { font-size: 0.72rem; color: var(--green); margin-top: 4px; }

.dashboard-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
}

.card {
  background: var(--dark3);
  border: 1px solid rgba(245,240,232,0.05);
  padding: 28px;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24px;
  padding-bottom: 16px;
  border-bottom: 1px solid rgba(245,240,232,0.06);
}

.card-title { font-size: 0.88rem; font-weight: 700; }

.activity-list { display: flex; flex-direction: column; gap: 14px; }

.activity-item {
  display: flex;
  align-items: flex-start;
  gap: 14px;
}

.activity-dot {
  width: 8px; height: 8px;
  background: var(--gold);
  border-radius: 50%;
  margin-top: 6px;
  flex-shrink: 0;
}

.activity-text { font-size: 0.82rem; color: var(--white-dim); line-height: 1.5; }
.activity-time { font-size: 0.7rem; color: rgba(245,240,232,0.3); margin-top: 2px; }

.quick-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

.quick-btn {
  background: var(--dark4);
  border: 1px solid rgba(245,240,232,0.06);
  padding: 18px 16px;
  cursor: pointer;
  text-align: center;
  transition: all 0.25s;
  font-family: 'Cairo', sans-serif;
  color: var(--white-dim);
  font-size: 0.82rem;
}

.quick-btn:hover { border-color: var(--gold); color: var(--gold); background: var(--gold-dim); }
.quick-btn .q-icon { font-size: 1.4rem; display: block; margin-bottom: 6px; }

/* ══════════════════════════════
   LOGO EDITOR
══════════════════════════════ */
.logo-editor-grid {
  display: grid;
  grid-template-columns: 1fr 380px;
  gap: 28px;
}

.logo-preview-area {
  background: var(--dark3);
  border: 1px solid rgba(245,240,232,0.06);
  padding: 40px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 40px;
  min-height: 480px;
}

.preview-on-dark, .preview-on-light {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  width: 100%;
}

.preview-label {
  font-size: 0.68rem;
  letter-spacing: 3px;
  color: var(--white-dim);
  text-transform: uppercase;
}

.preview-on-light .logo-display-area {
  background: #F5F0E8;
  width: 100%;
}

.logo-display-area {
  padding: 32px 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  background: var(--dark);
  border: 1px solid rgba(245,240,232,0.06);
}

/* GENERATED LOGO STYLES */
.logo-style-1 { /* Icon + Text horizontal */
  display: flex; align-items: center; gap: 14px;
}
.logo-style-2 { /* Stacked */
  display: flex; flex-direction: column; align-items: center; gap: 8px;
}
.logo-style-3 { /* Z monogram big */
  display: flex; align-items: center; gap: 0;
}

.logo-icon-box {
  width: 48px; height: 48px;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Playfair Display', serif;
  font-style: italic;
  font-size: 1.8rem;
}

.logo-text-group { display: flex; flex-direction: column; }
.logo-name { font-family: 'Playfair Display', serif; font-weight: 700; line-height: 1; }
.logo-tagline { letter-spacing: 4px; text-transform: uppercase; font-weight: 300; }

/* Controls panel */
.controls-panel {
  background: var(--dark3);
  border: 1px solid rgba(245,240,232,0.06);
  padding: 28px;
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.control-group { display: flex; flex-direction: column; gap: 10px; }
.control-label { font-size: 0.72rem; color: var(--gold); letter-spacing: 2px; text-transform: uppercase; }

.style-options { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }

.style-opt {
  background: var(--dark4);
  border: 2px solid transparent;
  padding: 12px 8px;
  cursor: pointer;
  text-align: center;
  font-size: 0.72rem;
  color: var(--white-dim);
  transition: all 0.2s;
  font-family: 'Cairo', sans-serif;
}

.style-opt:hover { border-color: rgba(201,168,76,0.3); color: var(--white); }
.style-opt.selected { border-color: var(--gold); color: var(--gold); background: var(--gold-dim); }
.style-opt-icon { font-size: 1.2rem; display: block; margin-bottom: 4px; }

.color-swatches { display: flex; gap: 8px; flex-wrap: wrap; }

.swatch {
  width: 32px; height: 32px;
  border-radius: 50%;
  cursor: pointer;
  border: 3px solid transparent;
  transition: all 0.2s;
}

.swatch.selected { border-color: var(--white); transform: scale(1.15); }

.input-field {
  background: var(--dark4);
  border: 1px solid rgba(245,240,232,0.1);
  color: var(--white);
  padding: 10px 14px;
  font-family: 'Cairo', sans-serif;
  font-size: 0.88rem;
  width: 100%;
  outline: none;
  transition: border-color 0.2s;
}

.input-field:focus { border-color: var(--gold); }

.range-slider {
  width: 100%;
  accent-color: var(--gold);
  cursor: pointer;
}

.download-options { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }

/* ══════════════════════════════
   CONTENT EDITOR
══════════════════════════════ */
.content-tabs {
  display: flex;
  gap: 2px;
  margin-bottom: 24px;
  border-bottom: 1px solid rgba(245,240,232,0.07);
}

.ctab {
  padding: 10px 20px;
  font-size: 0.82rem;
  color: var(--white-dim);
  cursor: pointer;
  border-bottom: 2px solid transparent;
  transition: all 0.2s;
  background: none;
  border-top: none; border-right: none; border-left: none;
  font-family: 'Cairo', sans-serif;
}

.ctab.active, .ctab:hover { color: var(--gold); border-bottom-color: var(--gold); }

.content-section { display: none; }
.content-section.active { display: block; }

.fields-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px; }
.field-full { grid-column: 1 / -1; }

.field-group { display: flex; flex-direction: column; gap: 8px; }
.field-label { font-size: 0.72rem; color: var(--white-dim); letter-spacing: 1px; }

.textarea-field {
  background: var(--dark4);
  border: 1px solid rgba(245,240,232,0.1);
  color: var(--white);
  padding: 12px 14px;
  font-family: 'Cairo', sans-serif;
  font-size: 0.88rem;
  width: 100%;
  outline: none;
  transition: border-color 0.2s;
  resize: vertical;
  min-height: 100px;
  line-height: 1.6;
}

.textarea-field:focus { border-color: var(--gold); }

/* Packages editor */
.packages-editor { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }

.pkg-card-edit {
  background: var(--dark4);
  border: 1px solid rgba(245,240,232,0.07);
  padding: 24px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.pkg-card-edit h4 { font-size: 0.8rem; color: var(--gold); margin-bottom: 4px; }

/* ══════════════════════════════
   PORTFOLIO
══════════════════════════════ */
.portfolio-toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24px;
  flex-wrap: wrap;
  gap: 12px;
}

.portfolio-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

.portfolio-item {
  background: var(--dark3);
  border: 1px solid rgba(245,240,232,0.05);
  overflow: hidden;
  position: relative;
  group: true;
  transition: border-color 0.3s;
}

.portfolio-item:hover { border-color: rgba(201,168,76,0.25); }

.portfolio-thumb {
  height: 160px;
  background: var(--dark4);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 3rem;
  position: relative;
  overflow: hidden;
  cursor: pointer;
}

.portfolio-thumb input[type=file] {
  position: absolute;
  inset: 0;
  opacity: 0;
  cursor: pointer;
  width: 100%;
  height: 100%;
}

.portfolio-thumb img {
  width: 100%; height: 100%;
  object-fit: cover;
  position: absolute;
  inset: 0;
}

.upload-hint {
  font-size: 0.72rem;
  color: var(--white-dim);
  text-align: center;
  margin-top: 4px;
}

.portfolio-info { padding: 16px; display: flex; flex-direction: column; gap: 8px; }
.portfolio-actions { display: flex; gap: 8px; }

.add-portfolio-card {
  background: var(--dark3);
  border: 2px dashed rgba(201,168,76,0.2);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8px;
  min-height: 240px;
  cursor: pointer;
  transition: all 0.3s;
  color: var(--white-dim);
  font-size: 0.82rem;
}

.add-portfolio-card:hover { border-color: var(--gold); color: var(--gold); background: var(--gold-dim); }
.add-portfolio-card .add-icon { font-size: 2rem; }

/* ══════════════════════════════
   CONTACT / WHATSAPP
══════════════════════════════ */
.contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }

.contact-preview {
  background: var(--dark3);
  border: 1px solid rgba(245,240,232,0.06);
  padding: 28px;
}

.whatsapp-btn-preview {
  display: flex;
  align-items: center;
  gap: 12px;
  background: #25D366;
  color: white;
  padding: 16px 24px;
  margin-top: 20px;
  font-family: 'Cairo', sans-serif;
  font-weight: 700;
  cursor: pointer;
  border: none;
  width: 100%;
  justify-content: center;
  font-size: 0.95rem;
}

.social-links-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 16px; }

.social-input-row {
  display: flex;
  align-items: center;
  gap: 10px;
  background: var(--dark4);
  border: 1px solid rgba(245,240,232,0.1);
  padding: 10px 14px;
  transition: border-color 0.2s;
}

.social-input-row:focus-within { border-color: var(--gold); }
.social-icon { font-size: 1.1rem; flex-shrink: 0; }
.social-input-row input { background: transparent; border: none; color: var(--white); font-family: 'Cairo', sans-serif; font-size: 0.82rem; outline: none; width: 100%; }

/* ══════════════════════════════
   COLORS
══════════════════════════════ */
.colors-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }

.color-card {
  background: var(--dark3);
  border: 1px solid rgba(245,240,232,0.06);
  padding: 28px;
}

.color-picker-row {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 16px;
  padding: 14px;
  background: var(--dark4);
  border: 1px solid rgba(245,240,232,0.06);
}

.color-picker-row input[type=color] {
  width: 44px; height: 44px;
  border: none;
  cursor: pointer;
  background: none;
  padding: 0;
  border-radius: 0;
}

.color-info { flex: 1; }
.color-name { font-size: 0.82rem; font-weight: 600; }
.color-hex { font-size: 0.72rem; color: var(--white-dim); font-family: monospace; }

.theme-presets { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-top: 20px; }

.theme-preset {
  cursor: pointer;
  border: 2px solid transparent;
  transition: all 0.2s;
  overflow: hidden;
}

.theme-preset:hover { border-color: var(--gold); transform: translateY(-2px); }
.theme-preset.selected { border-color: var(--gold); }

.theme-swatch {
  height: 48px;
  display: flex;
}

.theme-swatch-half { flex: 1; }

.theme-label { font-size: 0.68rem; color: var(--white-dim); text-align: center; padding: 6px; background: var(--dark4); }

/* ══════════════════════════════
   TOAST NOTIFICATION
══════════════════════════════ */
.toast {
  position: fixed;
  bottom: 24px;
  left: 32px;
  background: var(--dark3);
  border: 1px solid var(--gold);
  color: var(--white);
  padding: 14px 20px;
  font-size: 0.85rem;
  display: flex;
  align-items: center;
  gap: 10px;
  transform: translateY(80px);
  opacity: 0;
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  z-index: 999;
  min-width: 260px;
}

.toast.show { transform: translateY(0); opacity: 1; }
.toast-icon { color: var(--gold); font-size: 1.1rem; }

/* ══════════════════════════════
   MOBILE TOGGLE
══════════════════════════════ */
.hamburger {
  display: none;
  background: none;
  border: none;
  color: var(--white);
  font-size: 1.3rem;
  cursor: pointer;
  padding: 4px;
}

/* SCROLLBAR */
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: var(--dark2); }
::-webkit-scrollbar-thumb { background: rgba(201,168,76,0.3); border-radius: 2px; }

/* ══════════════════════════════
   RESPONSIVE
══════════════════════════════ */
@media (max-width: 960px) {
  .sidebar { transform: translateX(100%); }
  .sidebar.open { transform: translateX(0); }
  .main { margin-right: 0; }
  .hamburger { display: block; }
  .stats-grid { grid-template-columns: 1fr 1fr; }
  .dashboard-grid, .logo-editor-grid, .contact-grid, .colors-grid { grid-template-columns: 1fr; }
  .portfolio-grid { grid-template-columns: 1fr 1fr; }
  .packages-editor { grid-template-columns: 1fr; }
}

@media (max-width: 560px) {
  .content-area { padding: 20px; }
  .stats-grid { grid-template-columns: 1fr 1fr; }
  .portfolio-grid { grid-template-columns: 1fr; }
  .fields-grid { grid-template-columns: 1fr; }
}
</style>
</head>
<body>

<!-- ══════════ SIDEBAR ══════════ -->
<aside class="sidebar" id="sidebar">
  <div class="sidebar-logo">
    <div class="logo-mark">Z</div>
    <h2>Zozo Studio</h2>
    <span>لوحة التحكم</span>
  </div>

  <nav class="sidebar-nav">
    <div class="nav-section-label">الرئيسية</div>
    <div class="nav-item active" onclick="showPanel('dashboard', this)">
      <span class="nav-icon">⬡</span> نظرة عامة
    </div>

    <div class="nav-section-label">تخصيص الموقع</div>
    <div class="nav-item" onclick="showPanel('logo', this)">
      <span class="nav-icon">✦</span> اللوجو والهوية
    </div>
    <div class="nav-item" onclick="showPanel('content', this)">
      <span class="nav-icon">✏️</span> المحتوى والنصوص
    </div>
    <div class="nav-item" onclick="showPanel('portfolio', this)">
      <span class="nav-icon">🖼️</span> معرض الأعمال
      <span class="nav-badge">جديد</span>
    </div>
    <div class="nav-item" onclick="showPanel('colors', this)">
      <span class="nav-icon">🎨</span> الألوان والثيم
    </div>
    <div class="nav-item" onclick="showPanel('contact', this)">
