        <p style="color:var(--white-dim);font-size:0.88rem;line-height:1.8;margin-bottom:20px;">
          لتعديل محتوى منصة قران، اذهب إلى <strong style="color:var(--gold)">المحتوى والنصوص → تبويب قران</strong>
        </p>
        <button class="btn btn-gold" onclick="showPanel('content', null)">تعديل المحتوى ←</button>
      </div>
    </div>

  </div><!-- /content-area -->
</div><!-- /main -->

<!-- TOAST -->
<div class="toast" id="toast">
  <span class="toast-icon">✓</span>
  <span id="toast-msg">تم الحفظ بنجاح</span>
</div>

<script>
// ══════════════════════════════
// NAVIGATION
// ══════════════════════════════
const panelTitles = {
  dashboard: ['نظرة عامة', 'Dashboard'],
  logo: ['اللوجو والهوية البصرية', 'Logo & Brand Identity'],
  content: ['المحتوى والنصوص', 'Content Editor'],
  portfolio: ['معرض الأعمال', 'Portfolio'],
  colors: ['الألوان والثيم', 'Colors & Theme'],
  contact: ['بيانات التواصل', 'Contact Info'],
  agency: ['صفحة الوكالة', 'Agency Page'],
  prints: ['صفحة المطبوعات', 'Prints Page'],
  qeran: ['منصة قران', 'Qeran Platform'],
};

function showPanel(name, clickedEl) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('panel-' + name).classList.add('active');
  if (clickedEl) clickedEl.classList.add('active');
  const t = panelTitles[name] || [name, name];
  document.getElementById('topbar-title').textContent = t[0];
  document.getElementById('topbar-crumb').textContent = 'Zozo Studio / ' + t[1];
  // Close sidebar on mobile
  if (window.innerWidth < 960) document.getElementById('sidebar').classList.remove('open');
}

function toggleSidebar() {
  document.getElementById('sidebar').classList.toggle('open');
}

// ══════════════════════════════
// TOAST
// ══════════════════════════════
function showToast(msg, type = 'success') {
  const t = document.getElementById('toast');
  const icon = t.querySelector('.toast-icon');
  document.getElementById('toast-msg').textContent = msg;
  icon.textContent = type === 'success' ? '✓' : type === 'error' ? '✗' : 'ℹ';
  t.style.borderColor = type === 'success' ? 'var(--gold)' : type === 'error' ? 'var(--red)' : 'var(--blue)';
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3000);
}

// ══════════════════════════════
// LOGO EDITOR
// ══════════════════════════════
let logoState = {
  name: 'Zozo Studio',
  tagline: 'CREATIVE AGENCY',
  letter: 'Z',
  style: 'horizontal',
  iconShape: 'square',
  iconColor: '#C9A84C',
  iconTextColor: '#080808',
  nameSize: 1.6,
  nameColor: '#F5F0E8',
  tagColor: '#C9A84C',
};

function updateLogo() {
  logoState.name = document.getElementById('logo-name-input').value || 'Zozo Studio';
  logoState.tagline = document.getElementById('logo-tagline-input').value || 'CREATIVE AGENCY';
  logoState.letter = document.getElementById('logo-letter-input').value || 'Z';
  renderLogos();
}

function updateLogoSize(val) {
  logoState.nameSize = parseFloat(val);
  renderLogos();
}

function setLogoStyle(style, el) {
  logoState.style = style;
  document.querySelectorAll('.style-options .style-opt').forEach(o => {
    if (o.parentElement === el.parentElement) o.classList.remove('selected');
  });
  el.classList.add('selected');
  renderLogos();
}

function setIconShape(shape, el) {
  logoState.iconShape = shape;
  el.parentElement.querySelectorAll('.style-opt').forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
  renderLogos();
}

function setIconColor(color, el) {
  logoState.iconColor = color;
  logoState.iconTextColor = isLight(color) ? '#080808' : '#F5F0E8';
  document.querySelectorAll('.color-swatches .swatch').forEach(s => s.classList.remove('selected'));
  el.classList.add('selected');
  renderLogos();
}

function isLight(hex) {
  const r = parseInt(hex.slice(1,3),16), g = parseInt(hex.slice(3,5),16), b = parseInt(hex.slice(5,7),16);
  return (r*0.299 + g*0.587 + b*0.114) > 150;
}

function buildLogoHTML(darkBg) {
  const nameColor = darkBg ? '#F5F0E8' : '#080808';
  const { name, tagline, letter, style, iconShape, iconColor, iconTextColor, nameSize, tagColor } = logoState;

  const borderRadius = iconShape === 'circle' ? '50%' : '0';
  const bgStyle = iconShape === 'none' ? `background:transparent; color:${iconColor};` : `background:${iconColor}; color:${iconTextColor};`;

  const iconEl = `<div style="width:${nameSize*30}px;height:${nameSize*30}px;display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;font-style:italic;font-size:${nameSize*0.85}rem;border-radius:${borderRadius};${bgStyle}flex-shrink:0;">${letter}</div>`;

  const textEl = `<div style="display:flex;flex-direction:column;${style==='stacked'?'align-items:center;':''}">\
    <span style="font-family:'Playfair Display',serif;font-weight:700;font-size:${nameSize}rem;color:${nameColor};line-height:1;">${name}</span>\
    <span style="letter-spacing:4px;text-transform:uppercase;font-weight:300;font-size:${nameSize*0.35}rem;color:${tagColor};margin-top:2px;">${tagline}</span>\
  </div>`;

  if (style === 'monogram') {
    return `<div style="font-family:'Playfair Display',serif;font-style:italic;font-size:${nameSize*2.5}rem;color:${iconColor};line-height:1;">${letter}<span style="color:${nameColor};font-size:${nameSize*1.2}rem;">${name.replace(/^\S+\s?/,'')}</span></div>`;
  }
  if (style === 'stacked') {
    return `<div style="display:flex;flex-direction:column;align-items:center;gap:${nameSize*4}px;">${iconEl}${textEl}</div>`;
  }
  return `<div style="display:flex;align-items:center;gap:${nameSize*8}px;">${iconEl}${textEl}</div>`;
}

function renderLogos() {
  document.getElementById('logo-dark-preview').innerHTML = buildLogoHTML(true);
  document.getElementById('logo-light-preview').innerHTML = buildLogoHTML(false);
}

function downloadLogo(fmt) {
  const logoCode = buildLogoHTML(true);
  const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="400" height="120" viewBox="0 0 400 120">\
    <rect width="400" height="120" fill="#080808"/>\
    <text x="60" y="65" font-family="serif" font-size="48" font-style="italic" fill="#C9A84C">${logoState.letter}</text>\
    <text x="120" y="60" font-family="serif" font-size="28" fill="#F5F0E8">${logoState.name}</text>\
    <text x="122" y="82" font-family="sans-serif" font-size="10" letter-spacing="4" fill="#C9A84C">${logoState.tagline}</text>\
  </svg>`;

  if (fmt === 'svg') {
    const blob = new Blob([svg], {type:'image/svg+xml'});
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'zozo-studio-logo.svg';
    a.click();
    showToast('تم تنزيل اللوجو SVG ✓');
  } else {
    // PNG via canvas
    const canvas = document.createElement('canvas');
    canvas.width = 800; canvas.height = 240;
    const ctx = canvas.getContext('2d');
    ctx.fillStyle = '#080808';
    ctx.fillRect(0,0,800,240);
    ctx.fillStyle = '#C9A84C';
    ctx.font = 'italic bold 96px serif';
    ctx.fillText(logoState.letter, 80, 145);
    ctx.fillStyle = '#F5F0E8';
    ctx.font = 'bold 56px serif';
    ctx.fillText(logoState.name, 200, 130);
    ctx.fillStyle = '#C9A84C';
    ctx.font = '18px sans-serif';
    ctx.letterSpacing = '8px';
    ctx.fillText(logoState.tagline, 202, 168);
    canvas.toBlob(blob => {
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = 'zozo-studio-logo.png';
      a.click();
      showToast('تم تنزيل اللوجو PNG ✓');
    });
  }
}

function copyLogoCode() {
  const code = buildLogoHTML(true);
  navigator.clipboard.writeText(code).then(() => showToast('تم نسخ كود اللوجو ✓'));
}

// ══════════════════════════════
// CONTENT TABS
// ══════════════════════════════
function showContentTab(id, el) {
  document.querySelectorAll('.content-section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.ctab').forEach(t => t.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  if (el) el.classList.add('active');
}

// ══════════════════════════════
// PORTFOLIO
// ══════════════════════════════
let portfolioCount = 0;

function addPortfolioItem() {
  portfolioCount++;
  document.getElementById('portfolio-count').textContent = portfolioCount;
  const grid = document.getElementById('portfolio-grid');
  const addBtn = grid.querySelector('.add-portfolio-card');

  const item = document.createElement('div');
  item.className = 'portfolio-item';
  item.innerHTML = `
    <div class="portfolio-thumb" title="اضغط لرفع صورة">
      <span style="position:relative;z-index:1;font-size:2.5rem;color:rgba(245,240,232,0.2);">🖼️</span>
      <div style="position:absolute;bottom:8px;font-size:0.68rem;color:rgba(245,240,232,0.4);z-index:1;">اضغط لرفع صورة</div>
      <input type="file" accept="image/*" onchange="loadPortfolioImage(this)">
    </div>
    <div class="portfolio-info">
      <input class="input-field" style="margin-bottom:8px;" placeholder="اسم المشروع" value="مشروع ${portfolioCount}">
      <input class="input-field" style="margin-bottom:8px;" placeholder="نوع العمل (تصميم / فيديو...)">
      <div class="portfolio-actions">
        <button class="btn btn-danger btn-sm" onclick="this.closest('.portfolio-item').remove(); portfolioCount--; document.getElementById('portfolio-count').textContent=portfolioCount;">🗑 حذف</button>
        <button class="btn btn-outline btn-sm">⬆ نقل</button>
      </div>
    </div>`;

  grid.insertBefore(item, addBtn);
  addLog(`تم إضافة مشروع جديد (${portfolioCount})`);
  showToast('تم إضافة عمل جديد ✓');
}

function loadPortfolioImage(input) {
  if (!input.files[0]) return;
  const reader = new FileReader();
  reader.onload = e => {
    const thumb = input.closest('.portfolio-thumb');
    const existing = thumb.querySelector('img');
    if (existing) existing.remove();
    const img = document.createElement('img');
    img.src = e.target.result;
    thumb.insertBefore(img, thumb.firstChild);
    showToast('تم رفع الصورة ✓');
  };
  reader.readAsDataURL(input.files[0]);
}

// ══════════════════════════════
// COLORS
// ══════════════════════════════
function updateColor(key, val) {
  document.getElementById('hex-' + key).textContent = val;
}

function applyTheme(theme, el) {
  document.querySelectorAll('.theme-preset').forEach(p => p.classList.remove('selected'));
  el.classList.add('selected');
  const themes = {
    'gold-dark': { gold:'#C9A84C', dark:'#080808', white:'#F5F0E8', dark3:'#1A1A1A' },
    'blue-gold':  { gold:'#C9A84C', dark:'#0A1628', white:'#F5F0E8', dark3:'#122547' },
    'white-gold': { gold:'#B8941F', dark:'#FAFAFA', white:'#1A1A1A', dark3:'#F0EDE5' },
    'purple-gold':{ gold:'#E8C96A', dark:'#1A0A2E', white:'#F0ECF8', dark3:'#2A1545' },
  };
  const t = themes[theme];
  if (!t) return;
  Object.keys(t).forEach(k => {
    const el2 = document.getElementById('color-' + k);
    const hex = document.getElementById('hex-' + k);
    if (el2) el2.value = t[k];
    if (hex) hex.textContent = t[k];
  });
  showToast('تم تطبيق الثيم ✓');
}

function copyCSS() {
  const gold = document.getElementById('color-gold')?.value || '#C9A84C';
  const dark = document.getElementById('color-dark')?.value || '#080808';
  const white = document.getElementById('color-white')?.value || '#F5F0E8';
  const dark3 = document.getElementById('color-dark3')?.value || '#1A1A1A';
  const css = `:root {\n  --gold: ${gold};\n  --gold-light: ${gold}DD;\n  --gold-dim: ${gold}22;\n  --dark: ${dark};\n  --dark2: ${dark}F5;\n  --dark3: ${dark3};\n  --dark4: ${dark3}EE;\n  --white: ${white};\n  --white-dim: ${white}99;\n  --white-faint: ${white}12;\n}`;
  navigator.clipboard.writeText(css).then(() => showToast('تم نسخ كود CSS ✓'));
}

// ══════════════════════════════
// CONTACT
// ══════════════════════════════
function updateWhatsapp() {
  const num = document.getElementById('whatsapp-num').value.replace(/\D/g,'');
  const msg = encodeURIComponent(document.getElementById('wa-message')?.value || '');
  const url = `https://wa.me/${num}?text=${msg}`;
  const btn = document.getElementById('wa-preview-btn');
  if (btn) btn.onclick = () => num && window.open(url);
  const codeEl = document.getElementById('wa-code-output');
  if (codeEl && num) {
    codeEl.textContent = `<a href="${url}" target="_blank" class="btn-primary">💬 تواصل عبر واتساب</a>`;
  }
}

function generateContactCode() {
  const num = document.getElementById('whatsapp-num').value.replace(/\D/g,'');
  if (!num) { showToast('أدخل رقم واتساب أولاً', 'error'); return; }
  updateWhatsapp();
  showToast('تم توليد كود التواصل ✓');
}

function copyWACode() {
  const code = document.getElementById('wa-code-output')?.textContent;
  if (!code || code.includes('أدخل')) { showToast('أدخل رقم واتساب أولاً', 'error'); return; }
  navigator.clipboard.writeText(code).then(() => showToast('تم نسخ الكود ✓'));
}

// ══════════════════════════════
// SAVE / GLOBAL
// ══════════════════════════════
function saveAll() {
  const now = new Date();
  const time = now.toLocaleTimeString('ar-EG', {hour:'2-digit', minute:'2-digit'});
  document.getElementById('last-save').textContent = time;
  addLog('تم حفظ جميع التغييرات');
  showToast('✓ تم حفظ التغييرات بنجاح');
}

function previewSite() {
  showToast('افتح index.html في المتصفح لمعاينة الموقع', 'info');
}

function addLog(text) {
  const log = document.getElementById('activity-log');
  if (!log) return;
  const item = document.createElement('div');
  item.className = 'activity-item';
  item.innerHTML = `<span class="activity-dot" style="background:var(--gold)"></span>
    <div><div class="activity-text">${text}</div>
    <div class="activity-time">${new Date().toLocaleTimeString('ar-EG', {hour:'2-digit', minute:'2-digit'})}</div></div>`;
  log.insertBefore(item, log.firstChild);
}

// Init
renderLogos();
</script>
</body>
