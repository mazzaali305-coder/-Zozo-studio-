.section-tag::after{content:'';position:absolute;right:0;top:50%;width:24px;height:1px;background:var(--gold);}
html[dir="ltr"] .section-tag::after{right:auto;left:0;}
.section-title{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,3.5vw,2.7rem);line-height:1.18;margin-bottom:14px;}
