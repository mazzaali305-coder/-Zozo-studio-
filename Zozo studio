  .prob-card.solution{background:rgba(201,168,76,0.05);border:1px solid rgba(201,168,76,0.15);}
  .card-label{font-size:0.7rem;letter-spacing:3px;text-transform:uppercase;margin-bottom:24px;display:block;}
  .problem .card-label{color:#FF6B6B;}
