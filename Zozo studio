  .problem .prob-list li::before{content:'✗';position:absolute;right:0;color:#FF6B6B;}
  .solution .prob-list li::before{content:'✓';position:absolute;right:0;color:var(--gold);}

  /* HOW IT WORKS */
  .how-grid{display:grid;grid-template-columns:1fr 1fr;gap:56px;margin-top:52px;align-items:start;}
  .how-side h3{font-family:'Playfair Display',serif;font-size:1.3rem;margin-bottom:28px;color:var(--gold);}
