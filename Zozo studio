  .how-step-text h4{font-size:0.9rem;font-weight:700;margin-bottom:4px;}
  .how-step-text p{color:var(--white-dim);font-size:0.8rem;line-height:1.6;}

  /* FEATURES */
  .features{background:var(--blue);}
  .features-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:52px;}
  .feature-card{background:rgba(255,255,255,0.03);border:1px solid rgba(201,168,76,0.1);padding:36px 28px;transition:all 0.4s;}
  .feature-card:hover{background:rgba(201,168,76,0.05);border-color:rgba(201,168,76,0.25);transform:translateY(-4px);}
  .feature-icon{font-size:2rem;margin-bottom:16px;display:block;}
  .feature-card h3{font-size:1rem;font-weight:700;margin-bottom:10px;}
  .feature-card p{color:var(--white-dim);font-size:0.82rem;line-height:1.7;}

  /* WAITLIST */
  .waitlist{background:linear-gradient(135deg,var(--blue2),var(--dark));text-align:center;padding:100px 5%;}
  .waitlist-box{max-width:560px;margin:0 auto;}
  .waitlist h2{font-family:'Playfair Display',serif;font-size:clamp(2rem,4vw,3rem);margin-bottom:16px;}
  .waitlist h2 em{font-style:italic;color:var(--gold);}
  .waitlist p{color:var(--white-dim);line-height:1.8;margin-bottom:36px;}
  .waitlist-form{display:flex;flex-direction:column;gap:14px;text-align:right;}
  .form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
  .form-input{background:rgba(255,255,255,0.05);border:1px solid rgba(245,240,232,0.12);color:var(--white);padding:14px 18px;font-family:'Cairo',sans-serif;font-size:0.9rem;outline:none;transition:border 0.3s;width:100%;}
  .form-input:focus{border-color:var(--gold);}
  .form-input::placeholder{color:rgba(245,240,232,0.3);}
  .form-select{background:var(--dark3);border:1px solid rgba(245,240,232,0.12);color:var(--white);padding:14px 18px;font-family:'Cairo',sans-serif;font-size:0.9rem;width:100%;outline:none;cursor:pointer;}
  .btn-waitlist{background:var(--gold);color:var(--dark);padding:16px;font-family:'Cairo',sans-serif;font-weight:700;font-size:1rem;border:none;cursor:pointer;transition:all 0.3s;width:100%;}
  .btn-waitlist:hover{background:var(--gold-light);transform:translateY(-2px);}
  .form-note{color:rgba(245,240,232,0.3);font-size:0.75rem;text-align:center;}

  footer{background:var(--dark);border-top:1px solid rgba(201,168,76,0.1);padding:32px 5%;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px;}
  footer p{color:rgba(245,240,232,0.3);font-size:0.78rem;}
  footer a{color:var(--gold);text-decoration:none;font-size:0.82rem;}

  .reveal{opacity:0;transform:translateY(28px);transition:opacity 0.7s,transform 0.7s;}
  .reveal.visible{opacity:1;transform:translateY(0);}

  @media(max-width:768px){
    .prob-sol-grid{grid-template-columns:1fr;}
    .how-grid{grid-template-columns:1fr;}
    .features-grid{grid-template-columns:1fr 1fr;}
    .form-row{grid-template-columns:1fr;}
    .nav-links{display:none;}
    .hero-stats{position:static;margin-top:48px;}
  }
</style>
</head>
